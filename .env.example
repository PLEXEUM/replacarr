# Plex Configuration
PLEX_URL=http://192.168.0.77:32400
PLEX_TOKEN=your_plex_token_here

# Radarr Configuration
RADARR_URL=http://192.168.0.77:7878
RADARR_API_KEY=your_radarr_api_key_here

# Quality Settings
# Options: 480p, 720p, 1080p, 4k
DESIRED_QUALITY=1080p

# Time Window (days to look back for recently watched movies)
RECENT_DAYS=7

# Safety Limits
MAX_REPLACEMENTS_PER_RUN=3

# Skip recently processed (hours) - prevents retrying same movie if Radarr can't find upgrade
SKIP_HOURS=24

# Logging
# Options: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO